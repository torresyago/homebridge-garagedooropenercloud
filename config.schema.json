
{
  "name": "Shelly Garage Door Opener Cloud",
  "domain": "homebridge-garagedooropenercloud",
  "exclusive": true,
  "type": "object",
  "properties": {
    "name": {
      "title": "Nombre",
      "type": "string",
      "required": true,
      "default": "Garage Door"
    },
    "deviceId": {
      "title": "Shelly Device ID",
      "type": "string",
      "required": true,
      "placeholder": "e868e7d2b238"
    },
    "authKey": {
      "title": "Shelly Auth Key",
      "type": "string",
      "required": true,
      "placeholder": "MTAzNDEydWlk...",
      "format": "password"
    },
    "deviceType": {
      "title": "Tipo de dispositivo",
      "type": "string",
      "required": true,
      "enum": ["relay", "sensor"],
      "default": "relay"
    },
    "channel": {
      "title": "Canal",
      "type": "number",
      "default": 0,
      "minimum": 0
    },
    "openTime": {
      "title": "Tiempo de apertura (segundos)",
      "type": "number",
      "default": 20,
      "minimum": 1,
      "maximum": 120
    },
    "closeTime": {
      "title": "Tiempo de cierre (segundos)",
      "type": "number",
      "default": 20,
      "minimum": 1,
      "maximum": 120
    },
    "polling": {
      "title": "Polling activado",
      "type": "boolean",
      "default": true
    },
    "pollInterval": {
      "title": "Intervalo de polling (segundos)",
      "type": "number",
      "default": 30,
      "minimum": 10,
      "maximum": 300
    },
    "debug": {
      "title": "Modo debug",
      "type": "boolean",
      "default": false
    },
    "statusCloudURL": {
      "title": "URL de estado Shelly Cloud (opcional)",
      "type": "string",
      "required": false
    },
    "controlCloudURL": {
      "title": "URL de control Shelly Cloud (opcional)",
      "type": "string",
      "required": false
    }
  }
}

