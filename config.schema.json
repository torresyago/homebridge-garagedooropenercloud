{
  "pluginAlias": "GarageDoorOpenerCloud",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "Garage Door Cloud"
      },
      "shellyServer": {
        "title": "Shelly Cloud Server (default for all devices)",
        "type": "string",
        "placeholder": "https://shelly-38-eu.shelly.cloud",
        "description": "Your Shelly Cloud server URL. Find it in Shelly app → Settings → User Settings → Authorization cloud key → Server. Can be overridden per device."
      },
      "devices": {
        "title": "Garage Doors",
        "type": "array",
        "items": {
          "title": "Garage Door",
          "type": "object",
          "required": ["name", "deviceId", "authKey"],
          "properties": {
            "name": {
              "title": "Name",
              "type": "string",
              "description": "Name to appear in the Home app"
            },
            "deviceId": {
              "title": "Shelly Device ID",
              "type": "string",
              "description": "Device ID from Shelly App → Settings → Cloud → Advanced"
            },
            "authKey": {
              "title": "Shelly Auth Key",
              "type": "string",
              "description": "Auth Key from Shelly App → Profile"
            },
            "shellyServer": {
              "title": "Shelly Cloud Server (override)",
              "type": "string",
              "placeholder": "https://shelly-38-eu.shelly.cloud",
              "description": "Leave empty to use the platform-level server. Only set this if this device uses a different Shelly Cloud server."
            },
            "channel": {
              "title": "Channel",
              "type": "string",
              "default": "0",
              "description": "Relay channel (0 or 1)"
            },
            "deviceType": {
              "title": "Device Type",
              "type": "string",
              "default": "relay",
              "oneOf": [
                { "title": "Relay", "enum": ["relay"] },
                { "title": "Sensor", "enum": ["sensor"] }
              ]
            },
            "cloudBaseURL": {
              "title": "Cloud Control URL",
              "type": "string",
              "default": "https://shelly-38-eu.shelly.cloud/device/relay/control",
              "description": "Shelly Cloud relay control endpoint"
            },
            "statusCloudURL": {
              "title": "Cloud Status URL",
              "type": "string",
              "default": "https://shelly-38-eu.shelly.cloud/device/status",
              "description": "Shelly Cloud status endpoint"
            },
            "polling": {
              "title": "Enable Polling",
              "type": "boolean",
              "default": true,
              "description": "Poll real door state from Shelly Cloud"
            },
            "pollInterval": {
              "title": "Poll Interval (seconds)",
              "type": "integer",
              "default": 120,
              "minimum": 30,
              "description": "Seconds between status polls"
            },
            "manufacturer": {
              "title": "Manufacturer",
              "type": "string",
              "default": "Shelly Cloud",
              "description": "Manufacturer name in HomeKit"
            },
            "model": {
              "title": "Model",
              "type": "string",
              "description": "Model name in HomeKit"
            }
          }
        }
      }
    }
  }
}
